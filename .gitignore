# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# Node
node_modules/
.next/
.svelte-kit/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Pipeline reports (generated artifacts)
pipeline/reports/*.json

# Secrets
.secrets/

# Agent skills (installed ephemerally per CI job — not committed)
.cursor/skills/
.agents/skills/
skills-lock.json

# Test runner caches (vitest writes results.json to .vite/ when run locally
# inside src/frontend; never source-of-truth, would otherwise be attributed to
# whichever agent ran tests in its job)
.vite/

# Frontend lockfile is not committed yet (see AGENTS.md — npm install, not npm ci).
# When the agent runs npm in src/frontend, package-lock.json is untracked; without
# this entry it is misattributed to agent-1 and fails the src/** deny rule.
src/frontend/package-lock.json

# Local-only files
designboard.zip
user-data/

# Environment
.env
.env.local
.env.*.local
